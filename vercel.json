{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "dave.html", "use": "@vercel/static" },
    { "src": "tasks/index.html", "use": "@vercel/static" },
    { "src": "projects/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/dave", "dest": "/dave.html" },
    { "src": "/dave.html", "dest": "/dave.html" },
    { "src": "/tasks", "dest": "/tasks/index.html" },
    { "src": "/tasks/(.*)", "dest": "/tasks/index.html" },
    { "src": "/projects", "dest": "/projects/index.html" },
    { "src": "/projects/(.*)", "dest": "/projects/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
