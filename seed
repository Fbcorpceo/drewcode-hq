  <input id="pin" type="password" placeholder="Enter password" style="padding:14px 20px;background:rgba(255,255,255,0.05);border:0.5px solid rgba(255,255,255,0.15);border-radius:8px;color:#F5F7FA;font-size:15px;width:100%;max-width:280px;outline:none;font-family:inherit;text-align:center"/>
  <button id="pbtn" style="padding:12px 40px;background:rgba(212,168,67,0.1);border:0.5px solid rgba(212,168,67,0.4);border-radius:8px;color:#D4A843;font-size:13px;cursor:pointer;font-family:inherit;letter-spacing:1px">Enter</button>
  <div id="perr" style="font-size:12px;color:#E24B4A;display:none">Incorrect password. Try again.</div>
</div>

<div class="deck" id="deck">
  <div class="nav" id="nav"></div>
  <div class="slide" id="slide"></div>
  <div class="footer">
    <button class="fb" id="prev" onclick="go(-1)">Prev</button>
    <span class="pg" id="pg"></span>
    <button class="fb" id="next" onclick="go(1)">Next</button>
  </div>
</div>

