  document.getElementById("next").disabled=cur===slides.length-1;
  document.querySelectorAll(".nb").forEach(function(b,i){b.classList.toggle("on",i===cur);});
}

function go(d){var n=cur+d;if(n>=0&&n<slides.length){cur=n;render();}}

function init(){
  var nav=document.getElementById("nav");
