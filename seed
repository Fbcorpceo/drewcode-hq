function dotrow(color,title,sub){
  return '<div class="row"><div class="dot" style="background:'+color+'"></div><div><div style="font-size:13px;font-weight:500;color:'+W+'">'+title+'</div><div style="font-size:11px;color:'+M+';margin-top:2px;line-height:1.5">'+sub+'</div></div></div>';
