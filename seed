var G="#D4A843",W="#F5F7FA",M="#7A8A9A",B="#3B9EFF",R="#34C77B",O="#FF6B4A",cur=0;

document.getElementById("pbtn").onclick=unlock;
document.getElementById("pin").onkeydown=function(e){if(e.key==="Enter")unlock();};

function unlock(){
  if(document.getElementById("pin").value==="blocks888"){
    document.getElementById("pw").style.display="none";
    document.getElementById("deck").style.display="flex";
    init();
  } else {
    document.getElementById("perr").style.display="block";
    document.getElementById("pbtn").textContent="Incorrect";
    document.getElementById("pin").style.borderColor="#E24B4A";
    setTimeout(function(){
      document.getElementById("perr").style.display="none";
      document.getElementById("pbtn").textContent="Enter";
      document.getElementById("pin").style.borderColor="rgba(255,255,255,0.15)";
    },1800);
  }
}

function card(label,body,color){
  var c=color||G;
  return '<div class="card"><div style="font-size:10px;color:'+c+';font-weight:600;text-transform:uppercase;letter-spacing:2px;margin-bottom:8px">'+label+'</div><div style="font-size:12px;color:'+M+';line-height:1.75">'+body+'</div></div>';
}
function stat(n,l){
  return '<div class="card" style="padding:14px 10px;text-align:center"><div style="font-size:18px;font-weight:700;color:'+G+'">'+n+'</div><div style="font-size:11px;color:'+M+';margin-top:4px">'+l+'</div></div>';
}
function pill(k,v){
  return '<div style="background:rgba(255,255,255,0.03);border:0.5px solid rgba(255,255,255,0.07);border-radius:10px;padding:12px"><div style="font-size:10px;color:'+M+';margin-bottom:4px">'+k+'</div><div style="font-size:13px;font-weight:600;color:'+W+'">'+v+'</div></div>';
}
function accent(title,body,color){
  var c=color||G;
  return '<div style="border-left:2px solid '+c+'77;padding-left:14px;margin-bottom:10px"><div style="font-size:13px;font-weight:500;color:'+W+';margin-bottom:3px">'+title+'</div><div style="font-size:12px;color:'+M+';line-height:1.65">'+body+'</div></div>';
