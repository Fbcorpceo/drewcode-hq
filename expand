<title>FBCorp — Integrated Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #d4af37;
    --gold-dim: rgba(212,175,55,.65);
    --gold-glow: rgba(212,175,55,.15);
    --bg: #07080c;
    --surface: rgba(255,255,255,.025);
    --border: rgba(255,255,255,.07);
    --text: #e8e8f0;
    --muted: rgba(232,232,240,.4);
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'DM Sans', -apple-system, sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-weight: 300;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 20px 48px;
    display: flex; align-items: center; justify-content: space-between;
    background: linear-gradient(to bottom, rgba(7,8,12,.95), transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .nav-logo {
    font-family: var(--serif); font-size: 22px; font-weight: 400;
    color: #fff; letter-spacing: .04em; text-decoration: none;
  }
  .nav-logo span { color: var(--gold); }
  .nav-tag {
    font-size: 10px; letter-spacing: .2em; text-transform: uppercase;
    color: var(--gold-dim); border: 0.5px solid rgba(212,175,55,.2);
    padding: 5px 14px; border-radius: 20px;
  }

  /* COVER */
  .cover {
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; padding: 120px 32px 80px;
    position: relative; overflow: hidden;
  }
  .orb {
    position: absolute; border-radius: 50%; pointer-events: none;
    animation: breathe 8s ease-in-out infinite;
  }
  .o1 {
    width: min(800px, 120vw); height: min(800px, 120vw);
    background: radial-gradient(circle, rgba(212,175,55,.11) 0%, transparent 65%);
    top: -30%; left: 50%; transform: translateX(-50%);
  }
  .o2 {
    width: min(550px, 90vw); height: min(550px, 90vw);
    background: radial-gradient(circle, rgba(60,120,255,.08) 0%, transparent 65%);
    bottom: -10%; right: -10%; animation-delay: -3s;
  }
  .o3 {
    width: min(400px, 70vw); height: min(400px, 70vw);
    background: radial-gradient(circle, rgba(30,200,160,.07) 0%, transparent 65%);
    bottom: -5%; left: -8%; animation-delay: -5s;
  }
  @keyframes breathe {
    0%, 100% { opacity: 1; transform: translateX(-50%) scale(1); }
    50% { opacity: .7; transform: translateX(-50%) scale(1.06); }
  }
  .o2 { animation: breathe2 9s ease-in-out infinite -3s; }
  .o3 { animation: breathe3 11s ease-in-out infinite -5s; }
  @keyframes breathe2 { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.65;transform:scale(1.08)} }
  @keyframes breathe3 { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.6;transform:scale(1.05)} }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(212,175,55,.07);
    border: 0.5px solid rgba(212,175,55,.22);
    border-radius: 20px; padding: 6px 18px; margin-bottom: 40px;
    font-size: 10px; letter-spacing: .22em; text-transform: uppercase;
    color: var(--gold-dim); position: relative; z-index: 1;
    animation: fadeUp .9s ease both;
  }
  .pulse {
    width: 6px; height: 6px; border-radius: 50%; background: var(--gold);
    box-shadow: 0 0 10px var(--gold); animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.6;transform:scale(.8)} }

  .cover-h1 {
    font-family: var(--serif); font-size: clamp(48px, 9vw, 100px);
    font-weight: 300; line-height: 1.0; letter-spacing: -.02em;
    color: #fff; margin-bottom: 16px; position: relative; z-index: 1;
    animation: fadeUp .9s ease .15s both;
  }
  .cover-h1 em {
    font-style: italic;
    background: linear-gradient(135deg, #b8941f 0%, #f0d76a 40%, #e8c94a 70%, #b8941f 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .cover-sub {
    font-size: clamp(14px, 2vw, 17px); color: var(--muted);
    line-height: 1.7; max-width: 560px; margin: 0 auto 60px;
    position: relative; z-index: 1;
    animation: fadeUp .9s ease .3s both;
  }
  .cover-line {
    width: 1px; height: 60px;
    background: linear-gradient(to bottom, transparent, rgba(212,175,55,.5), transparent);
    margin: 0 auto 60px; animation: fadeUp .9s ease .45s both;
    position: relative; z-index: 1;
  }
  .kpi-row {
    display: flex; gap: clamp(28px, 6vw, 64px); justify-content: center;
    flex-wrap: wrap; position: relative; z-index: 1;
    animation: fadeUp .9s ease .6s both;
  }
  .kpi { text-align: center; }
  .kpi-n { font-family: var(--serif); font-size: clamp(28px, 4vw, 42px); font-weight: 300; color: #fff; }
  .kpi-n span { color: var(--gold); }
  .kpi-l { font-size: 10px; color: rgba(232,232,240,.3); letter-spacing: .18em; text-transform: uppercase; margin-top: 5px; }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }

  /* SEPARATOR */
  .sep {
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,.05), transparent);
    margin: 0 clamp(24px, 5vw, 60px);
  }

  /* SLIDES */
  .slide { padding: clamp(60px, 8vw, 96px) clamp(24px, 6vw, 60px); max-width: 1100px; margin: 0 auto; }
  .slide-label {
    font-size: 10px; font-weight: 500; letter-spacing: .26em;
    text-transform: uppercase; color: rgba(212,175,55,.5); margin-bottom: 12px;
  }
  .slide-h {
    font-family: var(--serif); font-size: clamp(28px, 4.5vw, 52px);
    font-weight: 300; color: #fff; letter-spacing: -.01em;
    line-height: 1.15; margin-bottom: 10px;
  }
  .slide-h strong { font-weight: 500; }
  .slide-sub {
    font-size: 14px; color: var(--muted); line-height: 1.75;
    margin-bottom: 48px; max-width: 600px;
  }

  .thesis-box {
    background: rgba(212,175,55,.04);
    border: 0.5px solid rgba(212,175,55,.2);
    border-radius: 20px; padding: 32px 36px; margin-bottom: 44px;
    position: relative; overflow: hidden;
  }
  .thesis-box::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(to right, transparent, rgba(212,175,55,.55), transparent);
  }
  .thesis-text {
    font-family: var(--serif); font-size: clamp(16px, 2.2vw, 20px);
    font-weight: 300; color: rgba(232,232,240,.82); line-height: 1.8;
  }
  .thesis-text strong { color: var(--gold); font-weight: 500; }

  /* FOUNDER */
  .founder-wrap {
    display: grid; grid-template-columns: 1fr 1fr;
    border-radius: 24px; overflow: hidden;
    border: 0.5px solid rgba(255,255,255,.08);
    min-height: 560px;
  }
  @media (max-width: 700px) { .founder-wrap { grid-template-columns: 1fr; } }
  .founder-photo-col { position: relative; overflow: hidden; min-height: 420px; }
  .founder-photo-col img {
    width: 100%; height: 100%; object-fit: cover; object-position: center top;
    display: block; filter: contrast(1.05) brightness(.9) saturate(.95);
  }
  .founder-photo-col::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to right, transparent 55%, #07080c 100%);
  }
  .founder-photo-col::before {
    content: ''; position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(to bottom, transparent 65%, rgba(7,8,12,.5) 100%);
  }
  .founder-info {
    background: rgba(255,255,255,.02); padding: clamp(32px, 5vw, 56px);
    display: flex; flex-direction: column; justify-content: center;
    position: relative; overflow: hidden;
  }
  .founder-info::before {
    content: ''; position: absolute; top: 0; left: 0; bottom: 0; width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(212,175,55,.25), transparent);
  }
  .founder-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(212,175,55,.08); border: 0.5px solid rgba(212,175,55,.2);
    border-radius: 12px; padding: 5px 14px; margin-bottom: 24px;
    font-size: 10px; letter-spacing: .18em; text-transform: uppercase;
    color: rgba(212,175,55,.75); width: fit-content;
  }
  .founder-name {
    font-family: var(--serif); font-size: clamp(36px, 5vw, 56px);
    font-weight: 300; color: #fff; letter-spacing: -.01em; margin-bottom: 4px;
  }
  .founder-title {
    font-size: 11px; color: var(--gold-dim); letter-spacing: .16em;
    text-transform: uppercase; margin-bottom: 30px;
  }
  .founder-quote {
    font-family: var(--serif); font-size: clamp(15px, 2vw, 18px);
    font-weight: 300; font-style: italic; color: rgba(232,232,240,.65);
    line-height: 1.75; border-left: 1.5px solid rgba(212,175,55,.35);
    padding-left: 20px; margin-bottom: 34px;
  }
  .founder-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 26px; }
  .f-stat {
    background: rgba(255,255,255,.03); border: 0.5px solid rgba(255,255,255,.07);
    border-radius: 12px; padding: 14px 16px;
  }
  .f-stat-n { font-family: var(--serif); font-size: 22px; font-weight: 300; color: #fff; }
  .f-stat-n span { color: var(--gold); }
  .f-stat-l { font-size: 10px; color: rgba(232,232,240,.32); letter-spacing: .12em; text-transform: uppercase; margin-top: 3px; }
  .credits { display: flex; flex-wrap: wrap; gap: 8px; }
  .credit {
    font-size: 10px; color: rgba(232,232,240,.35);
    border: 0.5px solid rgba(255,255,255,.08); border-radius: 8px;
    padding: 4px 10px; letter-spacing: .06em;
  }

  /* FLYWHEEL */
  .fw-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 14px; }
  .fw-card {
    background: var(--surface); border: 0.5px solid var(--border);
    border-radius: 16px; padding: 22px; position: relative; overflow: hidden;
    transition: border-color .3s, transform .3s;
  }
  .fw-card:hover { border-color: rgba(255,255,255,.14); transform: translateY(-3px); }
  .fw-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; }
  .fw-card.gold::before { background: linear-gradient(to right, transparent, rgba(212,175,55,.6), transparent); }
  .fw-card.blue::before { background: linear-gradient(to right, transparent, rgba(70,140,255,.6), transparent); }
  .fw-card.teal::before { background: linear-gradient(to right, transparent, rgba(40,200,165,.6), transparent); }
  .fw-card.purple::before { background: linear-gradient(to right, transparent, rgba(165,110,255,.6), transparent); }
  .fw-card-label { font-size: 10px; letter-spacing: .18em; text-transform: uppercase; margin-bottom: 10px; }
  .fw-card-label.gold { color: rgba(212,175,55,.65); }
  .fw-card-label.blue { color: rgba(70,140,255,.65); }
  .fw-card-label.teal { color: rgba(40,200,165,.65); }
  .fw-card-label.purple { color: rgba(165,110,255,.65); }
  .fw-card-name { font-family: var(--serif); font-size: 20px; font-weight: 400; color: #fff; margin-bottom: 8px; }
  .fw-card-desc { font-size: 12.5px; color: var(--muted); line-height: 1.65; }

  .arrow-bridge {
    display: flex; align-items: center; justify-content: center; gap: 12px;
    margin: 28px 0; font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
    color: rgba(232,232,240,.22);
  }
  .arrow-bridge span { flex: 1; height: 1px; background: rgba(212,175,55,.18); }
  .arrow-bridge em { color: rgba(212,175,55,.45); font-style: normal; white-space: nowrap; }

  .fw-hub {
    display: flex; align-items: center; justify-content: center; margin: 4px 0 28px;
  }
  .hub-node {
    width: 120px; height: 120px; border-radius: 50%;
    background: rgba(212,175,55,.07); border: 0.5px solid rgba(212,175,55,.3);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    box-shadow: 0 0 40px rgba(212,175,55,.13), 0 0 90px rgba(212,175,55,.05);
  }
  .hub-name { font-family: var(--serif); font-size: 14px; color: var(--gold); text-align: center; line-height: 1.3; }
  .hub-sub { font-size: 9px; color: rgba(212,175,55,.42); letter-spacing: .1em; text-transform: uppercase; margin-top: 3px; }

  /* OUTPUT CARDS */
  .out-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
  .out-card {
    background: var(--surface); border: 0.5px solid var(--border);
    border-radius: 18px; padding: 24px 22px; position: relative; overflow: hidden;
    transition: transform .3s, border-color .3s;
  }
  .out-card:hover { transform: translateY(-2px); border-color: rgba(255,255,255,.13); }
  .out-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; }
  .out-card.gold::before { background: linear-gradient(to right, transparent, rgba(212,175,55,.55), transparent); }
  .out-card.teal::before { background: linear-gradient(to right, transparent, rgba(40,200,165,.55), transparent); }
  .out-card.blue::before { background: linear-gradient(to right, transparent, rgba(70,140,255,.55), transparent); }
  .out-card.purple::before { background: linear-gradient(to right, transparent, rgba(165,110,255,.55), transparent); }
  .out-card.coral::before { background: linear-gradient(to right, transparent, rgba(255,110,75,.55), transparent); }
  .oc-tag { font-size: 10px; letter-spacing: .18em; text-transform: uppercase; margin-bottom: 10px; }
  .oc-tag.gold { color: rgba(212,175,55,.6); }
  .oc-tag.teal { color: rgba(40,200,165,.6); }
  .oc-tag.blue { color: rgba(70,140,255,.6); }
  .oc-tag.purple { color: rgba(165,110,255,.6); }
  .oc-tag.coral { color: rgba(255,110,75,.6); }
  .oc-name { font-family: var(--serif); font-size: 20px; font-weight: 400; color: #fff; margin-bottom: 8px; }
  .oc-desc { font-size: 12.5px; color: var(--muted); line-height: 1.65; margin-bottom: 16px; }
  .oc-list { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .oc-list li {
    font-size: 11.5px; color: rgba(232,232,240,.32);
    display: flex; align-items: flex-start; gap: 8px;
  }
  .oc-list li::before {
    content: ''; width: 4px; height: 4px; border-radius: 50%;
    margin-top: 5px; flex-shrink: 0;
  }
  .oc-list.gold li::before { background: rgba(212,175,55,.55); }
  .oc-list.teal li::before { background: rgba(40,200,165,.55); }
  .oc-list.blue li::before { background: rgba(70,140,255,.55); }
  .oc-list.purple li::before { background: rgba(165,110,255,.55); }
  .oc-list.coral li::before { background: rgba(255,110,75,.55); }
  .full-width { grid-column: 1 / -1; }

  /* MOAT */
  .moat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 36px; }
  @media (max-width: 600px) { .moat-grid { grid-template-columns: repeat(2, 1fr); } }
  .moat-card {
    background: rgba(255,255,255,.02); border: 0.5px solid rgba(255,255,255,.06);
    border-radius: 14px; padding: 22px 16px; text-align: center;
  }
  .moat-n { font-family: var(--serif); font-size: clamp(22px, 3.5vw, 32px); font-weight: 300; color: #fff; margin-bottom: 6px; }
  .moat-n span { color: var(--gold); }
  .moat-l { font-size: 11px; color: rgba(232,232,240,.3); letter-spacing: .1em; text-transform: uppercase; line-height: 1.5; }

  /* ASK */
  .ask-box {
    background: rgba(212,175,55,.04); border: 0.5px solid rgba(212,175,55,.22);
    border-radius: 24px; padding: clamp(36px, 6vw, 56px); text-align: center;
    position: relative; overflow: hidden;
  }
  .ask-box::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(to right, transparent, rgba(212,175,55,.65), transparent);
  }
  .ask-amt {
    font-family: var(--serif); font-size: clamp(52px, 10vw, 96px);
    font-weight: 300; color: #fff; letter-spacing: -.03em; margin-bottom: 6px;
  }
  .ask-amt span { color: var(--gold); }
  .ask-lbl { font-size: 10px; letter-spacing: .22em; text-transform: uppercase; color: rgba(232,232,240,.3); margin-bottom: 36px; }
  .use-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .use-pill {
    display: flex; flex-direction: column; align-items: center; gap: 5px;
    background: rgba(255,255,255,.03); border: 0.5px solid rgba(255,255,255,.08);
    border-radius: 14px; padding: 16px 18px; min-width: 100px;
  }
  .use-pct { font-family: var(--serif); font-size: 20px; font-weight: 400; color: #fff; }
  .use-pct span { color: var(--gold); }
  .use-nm { font-size: 10px; color: rgba(232,232,240,.32); letter-spacing: .08em; text-transform: uppercase; text-align: center; line-height: 1.5; }

  /* FOOTER */
  footer {
    text-align: center; padding: 48px 32px 40px;
    font-size: 10px; color: rgba(232,232,240,.16); letter-spacing: .14em;
    border-top: 1px solid rgba(255,255,255,.04); margin-top: 60px;
  }

  /* SCROLL REVEAL */
  .reveal { opacity: 0; transform: translateY(28px); transition: opacity .8s ease, transform .8s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
</style>
</head>
